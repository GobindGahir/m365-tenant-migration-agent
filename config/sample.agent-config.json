{
  "SourceTenant": {
    "TenantId": "source-tenant-id-or-domain",
    "PrimaryDomain": "source.contoso.com"
  },
  "TargetTenant": {
    "TenantId": "target-tenant-id-or-domain",
    "PrimaryDomain": "target.contoso.com"
  },
  "Discovery": {
    "IncludeUsers": true,
    "IncludeGroups": false,
    "IncludeSites": false,
    "MaxUsers": 250,
    "MaxGroups": 250,
    "MaxSites": 250
  },
  "Scope": {
    "UserMigrationGroupId": "source-migration-security-group-object-id",
    "SharedMailboxMigrationGroupId": "source-shared-mailbox-migration-security-group-object-id",
    "TeamsCsvPath": ".\\config\\sample.teams-scope.csv",
    "SharePointCsvPath": ".\\config\\sample.sharepoint-scope.csv",
    "DistributionListsCsvPath": ".\\config\\sample.distribution-lists-scope.csv",
    "SharedMailboxPermissionsCsvPath": ".\\config\\sample.shared-mailbox-permissions.csv"
  },
  "Provisioning": {
    "CreateUsers": false,
    "CreateSharedMailboxes": true,
    "ApplySharedMailboxPermissions": true,
    "CreateGroups": true,
    "CreateSecurityGroups": true,
    "CreateDistributionLists": true,
    "CreateTeams": false,
    "CreateSharePointSites": false,
    "PreProvisionOneDrive": false,
    "AssignLicenses": false
  },
  "Mappings": {
    "UserPrincipalNameDomain": "target.contoso.com",
    "GroupPrefix": "MIG-",
    "SecurityGroupPrefix": "SG-MIG-",
    "LicenseSkuMap": {
      "SPE_E3": "target-sku-guid-here",
      "SPE_E5": "target-sku-guid-here"
    }
  }
}
